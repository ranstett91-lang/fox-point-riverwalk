---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubNav from '../components/SubNav.astro';
import Champions from '../components/Champions.astro';
import SourcesNote from '../components/SourcesNote.astro';

const subnavSections = [
  { id: 'transit-gateway', label: 'Transit gateway' },
  { id: 'connecting-trails', label: 'Connecting trails' },
  { id: 'biking-walking', label: 'Biking & walking' },
  { id: 'policy-funding', label: 'Policy & funding' },
  { id: 'champions', label: 'Champions' },
];
---

<BaseLayout
  title="What This Means for Delaware | Claymont to Fox Point"
  description="A $90M transit gateway, the East Coast Greenway, and a half-mile of restored shoreline that could connect Delaware's largest single transit investment directly to the Delaware River."
  canonical="https://fox-point-riverwalk.vercel.app/what-this-means-for-delaware/"
  ogImageAlt="Aerial view of the Claymont Transportation Center near the Fox Point shoreline."
>
  <SubNav slot="subnav" sections={subnavSections} />

  <main id="main-content" tabindex="-1">
    <header class="panel page-intro">
      <p class="kicker">What This Means for Delaware</p>
      <h1>A $90M transit gateway, a half mile of shoreline, and the river they could connect.</h1>
      <p>The Claymont Regional Transportation Center is one of Delaware's largest single transit investments. Fox Point is the shoreline a short walk away.</p>
    </header>

    <figure class="precedent-figure delaware-anchor-figure">
      <svg
        class="delaware-anchor-svg"
        viewBox="0 0 720 260"
        preserveAspectRatio="xMidYMid meet"
        role="img"
        aria-labelledby="delaware-anchor-title delaware-anchor-desc"
        xmlns="http://www.w3.org/2000/svg"
      >
        <title id="delaware-anchor-title">Half a mile between the transit center and the river</title>
        <desc id="delaware-anchor-desc">A simplified map: the Harris B. McDowell III Transportation Center on the left, the Fox Point shoreline restoration in the middle, and the Delaware River on the right. The transit center and the river are roughly half a mile apart, with the Northeast Corridor rail line and Interstate 495 running between them.</desc>

        <rect x="0" y="0" width="720" height="260" fill="#f2eee5"/>

        <rect x="540" y="0" width="180" height="260" fill="#cbdfe8"/>
        <path d="M 540 60 Q 580 50 620 60 T 700 60" fill="none" stroke="#a8c5d8" stroke-width="1.5" opacity="0.7"/>
        <path d="M 540 110 Q 580 100 620 110 T 700 110" fill="none" stroke="#a8c5d8" stroke-width="1.5" opacity="0.7"/>
        <path d="M 540 170 Q 580 160 620 170 T 700 170" fill="none" stroke="#a8c5d8" stroke-width="1.5" opacity="0.7"/>
        <path d="M 540 220 Q 580 210 620 220 T 700 220" fill="none" stroke="#a8c5d8" stroke-width="1.5" opacity="0.7"/>
        <text x="630" y="35" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="12" font-weight="800" fill="#3a5e72" letter-spacing="1.5">DELAWARE RIVER</text>

        <line x1="260" y1="40" x2="260" y2="220" stroke="#1a1a1a" stroke-width="3" stroke-dasharray="10 6" opacity="0.7"/>
        <text x="260" y="245" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="10" font-weight="600" fill="#5b574e" letter-spacing="0.4">AMTRAK NEC</text>

        <line x1="340" y1="40" x2="340" y2="220" stroke="#8a8475" stroke-width="6" stroke-linecap="round" opacity="0.45"/>
        <text x="340" y="245" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="10" font-weight="600" fill="#5b574e" letter-spacing="0.4">I-495</text>

        <g transform="translate(110, 110)">
          <circle r="32" fill="#12362a" stroke="#fffaf2" stroke-width="3"/>
          <rect x="-14" y="-12" width="28" height="20" rx="2.5" fill="#fffaf2"/>
          <line x1="-9" y1="6" x2="-9" y2="11" stroke="#12362a" stroke-width="2"/>
          <line x1="9" y1="6" x2="9" y2="11" stroke="#12362a" stroke-width="2"/>
        </g>
        <text x="110" y="170" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="12" font-weight="800" fill="#12362a" letter-spacing="0.6">McDOWELL</text>
        <text x="110" y="186" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="12" font-weight="800" fill="#12362a" letter-spacing="0.6">TRANSIT CENTER</text>
        <text x="110" y="204" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="10" font-weight="600" fill="#607063">SEPTA · Amtrak · DART</text>

        <rect x="420" y="95" width="100" height="50" rx="6" fill="rgba(200, 116, 66, 0.22)" stroke="#c87442" stroke-width="2.5"/>
        <text x="470" y="124" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="12" font-weight="800" fill="#7a3e22" letter-spacing="0.4">FOX POINT</text>
        <text x="470" y="170" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="10" font-weight="600" fill="#7a3e22">2.7-acre restoration</text>

        <line x1="142" y1="110" x2="420" y2="120" stroke="#3a6e44" stroke-width="2" stroke-dasharray="5 4"/>
        <text x="280" y="100" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="11" font-weight="800" fill="#3a6e44" letter-spacing="0.6">~ ½ MILE</text>
      </svg>
      <figcaption class="precedent-figure-caption">
        Roughly half a mile separates the McDowell Transportation Center from the Fox Point shoreline. The rail line and I-495 run between them.
      </figcaption>
    </figure>

    <section class="panel" id="transit-gateway">
      <div class="section-header">
        <div>
          <p class="section-label">A $90M Transit Gateway</p>
          <h2>The Harris B. McDowell III Transportation Center opened in December 2023. Fox Point sits a half mile away.</h2>
        </div>
        <p class="section-copy">The Claymont Regional Transportation Center cost $90 million. More than $51 million came from the Federal Transit Administration, including a $10 million TIGER grant; the state put in $38 million. It opened December 4, 2023.</p>
      </div>

      <div class="corridor-brief-grid">
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">What the station offers</h3>
          <ul>
            <li>Over 800 parking spaces</li>
            <li>13 EV charging stations</li>
            <li>ADA-accessible high-level platforms</li>
            <li>Bicycle racks and repair stations</li>
          </ul>
        </article>
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">Who uses it</h3>
          <p>SEPTA’s Wilmington/Newark Line commuter rail, plus SEPTA and DART First State bus routes. About 1,200 SEPTA riders board in Claymont every weekday.</p>
        </article>
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">Who it’s named for</h3>
          <p>Harris B. McDowell III served Claymont in the Delaware State Senate from 1976 to 2021 — the longest tenure in the General Assembly’s history. At the dedication, Governor John Carney called him “the godfather of climate change legislation” in the state.</p>
        </article>
      </div>

      <p class="section-copy">A restored shoreline at Fox Point would link one of Delaware’s largest single transit investments directly to the Delaware River.</p>

      <SourcesNote sources={[
        { label: 'State of Delaware — Claymont Transportation Center dedication', href: 'https://news.delaware.gov/2023/11/27/new-claymont-transportation-center-dedicated/' },
      ]} />
    </section>

    <section class="panel" id="connecting-trails">
      <div class="section-header">
        <div>
          <p class="section-label">Connecting Trails</p>
          <h2>The East Coast Greenway runs through Claymont. Fox Point is the missing link to the river.</h2>
        </div>
        <p class="section-copy">The East Coast Greenway is a 3,000-mile route from Maine to Florida. It runs directly through Claymont and connects to the existing Fox Point Riverview Trail — about a mile of trail that is already in place. If Fox Point closes the gap, this stretch could become one of the longest continuous publicly accessible riverfronts on the Northeast Corridor.</p>
      </div>

      <div class="corridor-brief-grid">
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">What exists today</h3>
          <p>About one mile of the Fox Point Riverview Trail is already built. Delaware Greenways is a named project partner.</p>
        </article>
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">What the longer vision adds</h3>
          <p>The broader concept extends the shoreline corridor about two miles north to reach the Transit Center.</p>
        </article>
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">Honest framing</h3>
          <p>The Wilmington-to-Trenton stretch of the Greenway currently runs partly on roads and partly on existing trails. It is not yet a continuous publicly accessible riverfront.</p>
        </article>
      </div>

      <SourcesNote sources={[
        { label: 'East Coast Greenway — Mid-Atlantic states', href: 'https://greenway.org/states/mid-atlantic/pennsylvania/' },
      ]} />
    </section>

    <section class="panel" id="biking-walking">
      <div class="section-header">
        <div>
          <p class="section-label">Safer Biking And Walking</p>
          <h2>Closing the gap means car-free access to the Delaware.</h2>
        </div>
        <p class="section-copy">Delaware ranks sixth among U.S. states for bicycle friendliness. Restoring Fox Point closes a real gap on the ground.</p>
      </div>

      <div class="corridor-brief-grid">
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">State ranking</h3>
          <p>Sixth in the country for bicycle friendliness, per the League of American Bicyclists.</p>
        </article>
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">The Jack A. Markell Trail</h3>
          <p>A 16-mile round trip between the Wilmington Riverfront and historic New Castle — already a popular ride.</p>
        </article>
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">What Fox Point closes</h3>
          <p>The current gap forces cyclists onto Philadelphia Pike and the shoulders of I-495 to reach the river. The restored shoreline is the safer alternative.</p>
        </article>
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">Car-free access</h3>
          <p>The link between the Transit Center and the waterfront means people can reach the Delaware River without a car.</p>
        </article>
      </div>
    </section>

    <section class="panel" id="policy-funding">
      <div class="section-header">
        <div>
          <p class="section-label">Policy &amp; Funding</p>
          <h2>The federal, state, and county pieces a Fox Point project could draw on.</h2>
        </div>
        <p class="section-copy">Click each scope to expand the list of programs and plans Fox Point could draw on.</p>
      </div>

      <div class="policy-accordion">
        <details class="policy-row">
          <summary>
            <span class="policy-eyebrow">Federal</span>
            <span class="policy-summary">USDOT grants, CDC place-based health funding, HUD neighborhoods</span>
            <span class="policy-chevron" aria-hidden="true">+</span>
          </summary>
          <ul>
            <li>USDOT Safe Streets and Roads for All</li>
            <li>USDOT RAISE grants</li>
            <li>USDOT Active Transportation Infrastructure Investment Program</li>
            <li>HHS / CDC place-based health funding</li>
            <li>HUD Choice Neighborhoods</li>
          </ul>
        </details>

        <details class="policy-row">
          <summary>
            <span class="policy-eyebrow">State (Delaware)</span>
            <span class="policy-summary">DelDOT trust fund, climate plan, Claymont master plans</span>
            <span class="policy-chevron" aria-hidden="true">+</span>
          </summary>
          <ul>
            <li>DelDOT Community Transportation Trust Fund</li>
            <li>2025 Delaware Climate Action Plan</li>
            <li>North Claymont Area Master Plan (WILMAPCO, 2017)</li>
            <li>2025 WILMAPCO Claymont Area Master Plan — parks and open space were the top community-named priority</li>
          </ul>
        </details>

        <details class="policy-row">
          <summary>
            <span class="policy-eyebrow">County (New Castle)</span>
            <span class="policy-summary">Trail and open space planning, county park system</span>
            <span class="policy-chevron" aria-hidden="true">+</span>
          </summary>
          <ul>
            <li>County trail and open space planning</li>
            <li>County park system</li>
          </ul>
        </details>
      </div>
    </section>

    <section class="panel read-next" aria-label="Read next">
      <p class="section-label">Read Next</p>
      <div class="read-next-grid">
        <a class="read-next-card" href="/rail-corridor/">
          <p class="read-next-eyebrow">Rail Corridor</p>
          <h3>The climate stakes on the rail line that runs through this corridor.</h3>
          <span class="read-next-cta">Read →</span>
        </a>
        <a class="read-next-card" href="/ecological-restoration/">
          <p class="read-next-eyebrow">Ecological Restoration</p>
          <h3>The federal water rule and endangered sturgeon on this stretch of river.</h3>
          <span class="read-next-cta">Read →</span>
        </a>
      </div>
    </section>

    <section class="panel" id="champions">
      <div class="section-header">
        <div>
          <p class="section-label">Champions</p>
          <h2>The people whose record and position make this work possible.</h2>
        </div>
      </div>
      <Champions ids={['mcdowell', 'mcbride', 'lambert', 'cartier', 'cruce']} />
    </section>
  </main>
</BaseLayout>
