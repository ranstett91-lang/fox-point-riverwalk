          <span class="read-next-cta">Read →</span>
        </a>
        <a class="read-next-card" href="/ecological-restoration/">
          <p class="read-next-eyebrow">Ecological Restoration</p>
          <h3>A new federal water rule and two endangered sturgeon on this stretch.</h3>
          <span class="read-next-cta">Read →</span>
        </a>
      </div>
    </section>

    <section class="panel community-cta" aria-labelledby="cta-heading">
      <p class="section-label">What you can do</p>
      <h2 id="cta-heading">Tell the people who can move this.</h2>
      <p class="community-cta-lede">
        Funding is already on the table. What is still needed is the early work
        that turns pledges into permits and shovels. Constituent letters to
        Delaware's federal delegation are the most direct lever — they tell
        committees and agencies that Fox Point is a priority back home.
      </p>
      <div class="community-cta-actions">
        <a
          class="community-cta-btn community-cta-btn-primary"
          href="https://mcbride.house.gov/contact"
          target="_blank"
          rel="noopener"
        >
          Contact your representative →
        </a>
        <button
          class="community-cta-btn community-cta-btn-secondary"
          type="button"
          data-share-brief
          data-share-label="Share this brief"
          aria-live="polite"
        >
          Share this brief
        </button>
      </div>
      <p class="community-cta-fineprint">
        Not a Delaware constituent? You can still write to the
        <a
          href="https://www.epa.gov/aboutepa/regional-and-geographic-offices"
          target="_blank"
          rel="noopener"
        >EPA's regional office</a> about the Delaware River water-quality
        standard, or share this page with someone who is.
      </p>
    </section>

    <section class="library panel" id="library">
      <ResourceLibrary />
    </section>

    <script>
      // Web Share API with clipboard fallback. No external libraries,
      // CSP-safe (no inline event handlers). Wires up every
      // [data-share-brief] button on each astro:page-load, scoped via
      // AbortController so view-transitions don't leak listeners.
      //
      // The canonical label is read from the data-share-label attr —
      // NOT from textContent at click time — so rapid double-clicks
      // can't capture the transient "Link copied ✓" state as the
      // "original" to restore. Each button also tracks an in-flight
      // copy via a WeakSet so overlapping resets don't fight.
      let shareAbortController: AbortController | null = null;
      const restoreTimers = new WeakMap<HTMLButtonElement, number>();

      function initShareButtons() {
        shareAbortController?.abort();
        shareAbortController = new AbortController();
        const { signal } = shareAbortController;

        const buttons = document.querySelectorAll<HTMLButtonElement>('[data-share-brief]');

        const restoreLabel = (btn: HTMLButtonElement) => {
          const label = btn.dataset.shareLabel ?? 'Share';
          btn.textContent = label;
        };

        buttons.forEach((btn) => {
          btn.addEventListener('click', async () => {
            const shareData = {
              title: document.title,
              text: 'Claymont to Fox Point — project brief',
              url: window.location.href,
            };

            // 1) Web Share API — native sheet on mobile / some desktops.
            try {
              if (navigator.share && (!navigator.canShare || navigator.canShare(shareData))) {
                await navigator.share(shareData);
                return;
              }
            } catch (err) {
              if ((err as DOMException)?.name === 'AbortError') return;
              // Otherwise fall through to clipboard fallback.
            }

            // 2) Clipboard fallback.
            try {
              await navigator.clipboard.writeText(shareData.url);
              btn.textContent = 'Link copied ✓';
              // Cancel any pending restore from a previous click so the
              // newest click owns the next restoration window.
              const pending = restoreTimers.get(btn);
              if (pending) window.clearTimeout(pending);
              const timer = window.setTimeout(() => {
                restoreLabel(btn);
                restoreTimers.delete(btn);
              }, 2400);
              restoreTimers.set(btn, timer);
              return;
            } catch {
              // 3) Final fallback — mailto. Some browsers gate
              // clipboard access on permissions/secure-context.
              window.location.href =
                'mailto:?subject=' +
                encodeURIComponent(shareData.title) +
                '&body=' +
                encodeURIComponent(shareData.url);
            }
          }, { signal });
        });
      }
      document.addEventListener('astro:page-load', initShareButtons);
    </script>
  </main>
</BaseLayout>
