---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubNav from '../components/SubNav.astro';
import ResourceLibrary from '../components/ResourceLibrary.astro';

const subnavSections = [
  { id: 'site', label: 'Site' },
  { id: 'funding', label: 'Funding' },
  { id: 'stakes', label: 'Stakes' },
  { id: 'library', label: 'Sources' },
];
---

<BaseLayout
  title="Claymont to Fox Point | Project Brief"
  description="Project brief for Fox Point Cove: a 2.7-acre wetland restoration with about $5.03M already linked to the site, a state plan, and the early work needed to turn pledges into shovels."
  canonical="https://fox-point-riverwalk.vercel.app/"
  ogImageAlt="Aerial concept rendering of the Claymont-to-Fox-Point corridor: Delaware River, living-shoreline boardwalk, Amtrak train along the Northeast Corridor, and I-495."
  preloadHero={true}
>
  <Fragment slot="hero">
    <div class="hero-fullbleed">
      <img
        src="/assets/hero-claymont-to-fox-point-state-park.jpg"
        alt="Aerial concept rendering of the Claymont-to-Fox-Point corridor: Delaware River on the left, a living shoreline trail and boardwalk with people walking and biking, an Amtrak train along the Northeast Corridor rail line, and I-495 to the right"
        class="hero-fb-photo"
        width="1920"
        height="1080"
        fetchpriority="high"
      />
      <div class="hero-fb-overlay"></div>
      <div class="hero-fb-content">
        <section class="hero-copy hero-copy-light">
          <p class="kicker kicker-light">Project Brief</p>
          <h1>Help reconnect Claymont to a cleaner, safer shoreline.</h1>
          <p class="lede lede-light">
            The first phase — restoring Fox Point Cove — already has $5M in pledges and a state plan.
            What is still needed is the early work that turns that plan into permits and shovels.
            Long-term, the vision continues the shoreline north to the Claymont Transit Center.
          </p>
          <div class="hero-points hero-points-light">
            <span>$5M pledged</span>
            <span>State plan</span>
            <span>203 river acres</span>
            <span>Early work is the gap</span>
          </div>
        </section>
      </div>
      <div class="hero-fb-chips" aria-hidden="true">
        <span>Delaware River →</span>
        <span>Living shoreline</span>
        <span>Rail line</span>
        <span>← Port of Edgemoor</span>
      </div>
    </div>

    <section class="skim-band" aria-label="Executive skim">
      <article class="skim-card">
        <h2 class="skim-title">What is this?</h2>
        <p class="skim-copy">A 2.7-acre wetland restoration at Fox Point Cove, with a long-term vision continuing the shoreline north to the Claymont Transit Center.</p>
      </article>
      <article class="skim-card">
        <h2 class="skim-title">Has anyone committed money?</h2>
        <p class="skim-copy">$5.03M is already linked to the site across three funding sources — a state bond pledge, a DNREC restoration line, and a NOAA settlement.</p>
      </article>
      <article class="skim-card">
        <h2 class="skim-title">Is there a plan?</h2>
        <p class="skim-copy">DNREC named the site in a January 2025 plan. The state has outlined the work and the next steps.</p>
      </article>
      <article class="skim-card">
        <h2 class="skim-title">What is missing?</h2>
        <p class="skim-copy">Design, permits, and the coordination to turn pledges into construction.</p>
      </article>
    </section>
  </Fragment>

  <SubNav slot="subnav" sections={subnavSections} />

  <main id="main-content" tabindex="-1">
    <section class="photo-section" id="site">
      <div class="photo-header">
        <p class="section-label">Site Readiness</p>
        <h2>Phase 1 restores the cove. The vision reconnects the shoreline to the Claymont Transit Center.</h2>
        <p class="photo-lead-in">The orange box is Phase 1. The green segment is the trail that already exists. The dashed segment is the long-term vision — about 2 miles of shoreline north to the Transit Center.</p>
      </div>
      <div class="photo-card">
        <svg
          class="site-schematic site-schematic--landscape"
          viewBox="0 0 1200 520"
          preserveAspectRatio="xMidYMid meet"
          role="img"
          aria-labelledby="schematic-title schematic-desc"
          xmlns="http://www.w3.org/2000/svg"
        >
          <title id="schematic-title">Schematic of the Claymont-to-Fox-Point shoreline reconnection</title>
          <desc id="schematic-desc">A ribbon schematic of a roughly three-mile shoreline corridor running south from the Claymont Transit Center. The top two-thirds of the ribbon shows the long-term reconnection vision, about two miles of shoreline not yet built. The bottom third shows the existing Fox Point Riverview Trail, about one mile already in place. Inside the existing-trail segment, Fox Point Cove is highlighted in orange as Phase 1, a 2.7-acre wetland restoration with $5M in pledges. The Amtrak Northeast Corridor rail line runs inland of the ribbon; the Delaware River forms its eastern edge.</desc>

          <rect x="0" y="0" width="1200" height="520" fill="#f2eee5"/>
          <defs>
            <pattern id="landTexture" width="14" height="14" patternUnits="userSpaceOnUse" patternTransform="rotate(35)">
              <line x1="0" y1="0" x2="0" y2="14" stroke="#d6e1d4" stroke-width="1" opacity="0.55"/>
            </pattern>
            <pattern id="waterTexture" width="60" height="22" patternUnits="userSpaceOnUse">
              <path d="M 0 11 Q 15 4 30 11 T 60 11" fill="none" stroke="#a8c5d8" stroke-width="1" opacity="0.55"/>
            </pattern>
          </defs>
          <rect x="0" y="0" width="1200" height="520" fill="url(#landTexture)"/>

          <rect x="880" y="0" width="320" height="520" fill="#cbdfe8"/>
          <rect x="880" y="0" width="320" height="520" fill="url(#waterTexture)"/>
          <line x1="880" y1="0" x2="880" y2="520" stroke="#12362a" stroke-width="2" opacity="0.5"/>

          <line x1="180" y1="60" x2="180" y2="475" stroke="#8a8475" stroke-width="6" stroke-linecap="round" opacity="0.4"/>
