---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubNav from '../components/SubNav.astro';
import Champions from '../components/Champions.astro';
import Callout from '../components/Callout.astro';
import SourcesNote from '../components/SourcesNote.astro';

const subnavSections = [
  { id: 'species', label: 'The species at stake' },
  { id: 'the-rule', label: 'The federal rule' },
  { id: 'what-fox-point-delivers', label: 'What Fox Point delivers' },
  { id: 'policy-funding', label: 'Policy & funding' },
  { id: 'champions', label: 'Champions' },
];
---

<BaseLayout
  title="Ecological Restoration | Claymont to Fox Point"
  description="Two endangered sturgeon, a new federal water rule, and a restoration plan that lines up with both. How Fox Point fits the federal standard for the Delaware River."
  canonical="https://fox-point-riverwalk.vercel.app/ecological-restoration/"
  ogImageAlt="Aerial view of the Delaware River shoreline near Fox Point, in the federally protected sturgeon habitat stretch."
>
  <SubNav slot="subnav" sections={subnavSections} />

  <main id="main-content" tabindex="-1">
    <header class="panel page-intro">
      <p class="kicker">Ecological Restoration</p>
      <h1>Two endangered sturgeon and a new federal water rule both point to this stretch of river.</h1>
      <p>A 38-mile stretch of the Delaware River — including Fox Point — sits inside federal sturgeon habitat and, since November 2025, a higher federal standard for dissolved oxygen. Fox Point’s restoration plan does complementary work on that same stretch.</p>
    </header>

    <section class="panel" id="species">
      <div class="section-header">
        <div>
          <p class="section-label">The Species At Stake</p>
          <h2>Two federally endangered sturgeon use this stretch of the river.</h2>
        </div>
        <p class="section-copy">Atlantic Sturgeon are fish that move between fresh and salt water.</p>
      </div>

      <figure class="feature-stat">
        <svg
          class="feature-stat-art"
          viewBox="0 0 420 120"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          focusable="false"
        >
          <!-- Atlantic Sturgeon (Acipenser oxyrinchus oxyrinchus) — drawn
               left-facing to match the rostrum's natural orientation in
               most reference photography. Anatomically driven by the
               diagnostic features:
                 • Long pointed rostrum (snout)
                 • 4 barbels under the chin (sensory whiskers)
                 • 5 rows of bony scutes: dorsal ridge + lateral lines
                 • Underslung mouth, set back from rostrum tip
                 • Single dorsal fin set far back (near tail)
                 • Anal fin opposite dorsal, set back too
                 • Heterocercal (asymmetric) tail with elongated upper lobe
                 • Pectoral fins low and forward, pelvic fins mid-belly
               currentcolor-driven so the illustration inherits theme. -->

          <!-- Body silhouette: spindle-shaped with pointed rostrum on
               the LEFT, narrowing into the caudal peduncle on the right. -->
          <g fill="currentColor" opacity="0.20">
            <path d="M 12 64
                     L 38 58 L 64 52 Q 80 50 100 49
                     Q 160 47 240 49
                     Q 300 51 340 56
                     Q 360 60 372 64
                     L 372 76
                     Q 360 80 340 84
                     Q 300 89 240 91
                     Q 160 93 100 91
                     Q 80 90 64 88
                     L 38 82 Z" />
          </g>

          <!-- Caudal peduncle taper into heterocercal tail.
               Upper lobe is roughly 2–3x longer than lower lobe — the
               diagnostic shark-like asymmetry of sturgeon caudal fins. -->
          <g fill="currentColor" opacity="0.30">
            <path d="M 372 64
                     L 396 28 L 412 22 L 408 40 L 396 60
                     L 408 70 L 412 86 L 396 80 L 372 76 Z" />
          </g>

          <!-- Single dorsal fin, set FAR BACK toward the tail
               (~73% along body) — characteristic of sturgeon. -->
          <g fill="currentColor" opacity="0.36">
            <path d="M 286 49 L 304 28 L 326 30 L 334 49 Z" />
          </g>

          <!-- Anal fin, mirroring the dorsal across the body axis. -->
          <g fill="currentColor" opacity="0.32">
            <path d="M 290 91 L 306 110 L 326 108 L 334 91 Z" />
          </g>

          <!-- Pectoral fin: large, set low and forward (~25% along body),
               trailing back along the underbelly. -->
          <g fill="currentColor" opacity="0.32">
            <path d="M 92 86 L 108 108 L 138 104 L 122 88 Z" />
          </g>

          <!-- Pelvic fin: smaller, set mid-belly (~52% along body). -->
          <g fill="currentColor" opacity="0.28">
            <path d="M 200 90 L 214 106 L 234 102 L 224 90 Z" />
          </g>

          <!-- Dorsal scute row — the diagnostic feature. Five spiked
               plates along the spine, increasing in size toward the
               head where the armor is thickest. -->
          <g fill="currentColor" opacity="0.55">
            <path d="M 86 47 L 94 36 L 102 47 Z" />
            <path d="M 124 45 L 132 34 L 140 45 Z" />
            <path d="M 164 44 L 172 33 L 180 44 Z" />
            <path d="M 204 44 L 212 33 L 220 44 Z" />
            <path d="M 244 44 L 252 33 L 260 44 Z" />
            <path d="M 282 45 L 290 34 L 298 45 Z" />
          </g>

          <!-- Lateral scute line — the row of plates along the side -->
          <path d="M 70 70 L 320 73"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                opacity="0.32" />

          <!-- Gill slit (curved opening just behind head) -->
          <path d="M 64 56 Q 60 64 64 76"
                fill="none"
                stroke="currentColor"
                stroke-width="1.2"
                stroke-linecap="round"
                opacity="0.40" />

          <!-- Eye: small, set high on the head, well back from rostrum tip -->
          <circle cx="44" cy="62" r="2.2" fill="currentColor" opacity="0.75" />

          <!-- Underslung mouth — diagnostic of sturgeon (extensible,
               positioned on the underside, set well back from the
               rostrum tip). Drawn as a subtle slit. -->
          <path d="M 22 78 Q 30 82 40 79"
                fill="none"
                stroke="currentColor"
                stroke-width="1.1"
                stroke-linecap="round"
                opacity="0.50" />

          <!-- Four barbels under the rostrum — the sensory whiskers
               sturgeon use to find prey on the river bottom. Hanging
               in a row between the rostrum tip and the mouth. -->
          <g stroke="currentColor" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.60">
            <path d="M 20 76 Q 17 84 14 92" />
            <path d="M 26 78 Q 24 86 22 94" />
            <path d="M 32 78 Q 31 86 30 94" />
            <path d="M 38 78 Q 38 86 38 94" />
          </g>
        </svg>
        <p class="feature-stat-num">&lt; 250</p>
        <figcaption class="feature-stat-label">
          spawning Atlantic Sturgeon left in the Delaware River population —
          a genetically unique line that has lived in this stretch for over
          100 million years.
        </figcaption>
      </figure>

      <Callout label="Worth building in from day one">
        <p>The Hudson Highlands Fjord Trail — the precedent project named on the project brief — has had its southern section delayed at least two years over concerns about these exact two species in the Hudson River. Building sturgeon protection into Fox Point’s design from the start protects both the species and the project schedule.</p>
      </Callout>

      <div class="corridor-brief-grid">
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">Atlantic Sturgeon</h3>
          <p>Federally designated critical habitat runs 137 kilometers from the Route 1 Toll Bridge in Trenton down to Hope Creek, NJ. Fox Point sits well inside that zone, in nursery and migration habitat.</p>
        </article>
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">Shortnose Sturgeon</h3>
          <p>Smaller than the Atlantic Sturgeon and also federally endangered. The two species share much of the same habitat in this stretch of the river.</p>
        </article>
      </div>

      <SourcesNote sources={[
        { label: 'DRBC sturgeon page', href: 'https://www.nj.gov/drbc/basin/living/atlantic-sturgeon.html' },
        { label: 'DNREC sturgeon page', href: 'https://dnrec.delaware.gov/fish-wildlife/fishing/sturgeon/' },
        { label: 'Delaware Riverkeeper Network', href: 'https://delawareriverkeeper.org/issues/species-protection/atlantic-sturgeon/' },
        { label: 'Highlands Current — HHFT southern section delay', href: 'https://highlandscurrent.org/2026/02/10/fjord-trail-to-prioritize-northern-section/' },
      ]} />
    </section>

    <section class="panel" id="the-rule">
      <div class="section-header">
        <div>
          <p class="section-label">The New Federal Rule</p>
          <h2>The Delaware River has a new federal water standard, and Fox Point sits inside the stretch it protects.</h2>
        </div>
        <p class="section-copy">On November 28, 2025, a new federal water rule took effect along a 38-mile stretch of the Delaware River — from Philadelphia down to Wilmington. Fox Point sits inside that stretch.</p>
      </div>

      <div class="corridor-brief-grid">
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">What the rule does</h3>
          <p>It sets a higher bar for dissolved oxygen — the part of water that fish and other river life need to breathe. The two endangered sturgeon are the reason it exists.</p>
        </article>
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">When it protects them</h3>
          <ul>
            <li>Spawning · March 1 – June 30</li>
            <li>Juveniles growing · July 1 – October 31</li>
            <li>Overwintering · November 1 – end of February</li>
          </ul>
        </article>
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">Where the work goes</h3>
          <p>In December 2025, the Delaware River Basin Commission began the technical work that helps the states meet the new standard. Most of the conversation has been about wastewater plant upgrades. Less attention has gone to nature-based projects that do complementary work.</p>
        </article>
      </div>

      <SourcesNote sources={[
        { label: 'EPA final rule (water quality standards, Delaware River)', href: 'https://www.epa.gov/wqs-tech/water-quality-standards-delaware-river' },
        { label: 'Federal Register Doc 2025-18816', href: 'https://www.federalregister.gov/documents/2025/09/29/2025-18816/water-quality-standards-to-protect-aquatic-life-in-the-delaware-river' },
      ]} />
    </section>

    <section class="panel" id="what-fox-point-delivers">
      <div class="section-header">
        <div>
          <p class="section-label">What Fox Point Delivers</p>
          <h2>The restoration plan lines up with the new standard in clear ways.</h2>
        </div>
        <p class="section-copy">Fox Point alone does not fix dissolved oxygen for the whole river — wastewater treatment upgrades are the main lever. But the restoration plan does complementary work the new rule cares about.</p>
      </div>

      <figure class="shoreline-figure">
        <svg
          class="shoreline-svg"
          viewBox="0 0 720 240"
          preserveAspectRatio="xMidYMid meet"
          role="img"
          aria-labelledby="shoreline-title shoreline-desc"
          xmlns="http://www.w3.org/2000/svg"
        >
          <title id="shoreline-title">Living shoreline cross-section</title>
          <desc id="shoreline-desc">A simplified cross-section moving from the industrial upland on the left, down through a stabilized bank, into a vegetated tidal marsh, and out to the Delaware River on the right. Three labels mark the three jobs the living shoreline does: stabilize the bank, scrub nitrogen from runoff with marsh plants, and provide nursery habitat in a federal sturgeon zone.</desc>

          <rect x="0" y="0" width="720" height="240" fill="#f2eee5"/>

          <rect x="0" y="0" width="180" height="240" fill="#e6dfd0"/>
          <line x1="180" y1="0" x2="180" y2="240" stroke="#b59a76" stroke-width="2" stroke-dasharray="6 4" opacity="0.7"/>
          <text x="90" y="34" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="11" font-weight="800" fill="#7a5a30" letter-spacing="0.6">INDUSTRIAL UPLAND</text>

          <path d="M 180 60 L 290 145 L 380 175 L 480 195 L 720 195 L 720 240 L 180 240 Z" fill="#d8e7d7" stroke="#3a6e44" stroke-width="2"/>

          <path d="M 220 145 Q 230 130 240 145 Q 250 130 260 145 Q 270 130 280 145" fill="none" stroke="#3a6e44" stroke-width="2"/>
          <path d="M 300 158 Q 310 143 320 158 Q 330 143 340 158" fill="none" stroke="#3a6e44" stroke-width="2"/>
          <path d="M 360 172 Q 370 157 380 172 Q 390 157 400 172 Q 410 157 420 172" fill="none" stroke="#3a6e44" stroke-width="2"/>
          <path d="M 440 187 Q 450 172 460 187 Q 470 172 480 187" fill="none" stroke="#3a6e44" stroke-width="2"/>

          <rect x="480" y="195" width="240" height="45" fill="#cbdfe8"/>
          <path d="M 480 217 Q 510 210 540 217 T 600 217 T 660 217 T 720 217" fill="none" stroke="#a8c5d8" stroke-width="1.5" opacity="0.7"/>
          <path d="M 480 230 Q 510 223 540 230 T 600 230 T 660 230 T 720 230" fill="none" stroke="#a8c5d8" stroke-width="1.5" opacity="0.7"/>

          <line x1="225" y1="100" x2="225" y2="135" stroke="#7a3e22" stroke-width="1.5"/>
          <circle cx="225" cy="98" r="3.5" fill="#c87442"/>
          <text x="225" y="78" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="11" font-weight="800" fill="#7a3e22" letter-spacing="0.4">STABILIZE</text>
          <text x="225" y="90" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="11" font-weight="800" fill="#7a3e22" letter-spacing="0.4">THE BANK</text>

          <line x1="365" y1="120" x2="365" y2="165" stroke="#7a3e22" stroke-width="1.5"/>
          <circle cx="365" cy="118" r="3.5" fill="#c87442"/>
          <text x="365" y="98" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="11" font-weight="800" fill="#7a3e22" letter-spacing="0.4">FILTER</text>
          <text x="365" y="110" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="11" font-weight="800" fill="#7a3e22" letter-spacing="0.4">NITROGEN</text>

          <line x1="580" y1="155" x2="580" y2="215" stroke="#7a3e22" stroke-width="1.5"/>
          <circle cx="580" cy="153" r="3.5" fill="#c87442"/>
          <text x="580" y="133" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="11" font-weight="800" fill="#7a3e22" letter-spacing="0.4">STURGEON</text>
          <text x="580" y="145" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="11" font-weight="800" fill="#7a3e22" letter-spacing="0.4">HABITAT</text>

          <text x="660" y="34" text-anchor="middle" font-family="Avenir Next, Segoe UI, sans-serif" font-size="11" font-weight="800" fill="#3a5e72" letter-spacing="1.5">DELAWARE RIVER</text>
        </svg>
        <figcaption class="shoreline-caption">A living shoreline at Fox Point does three jobs at once: it stabilizes the eroding industrial bank, lets marsh plants pull nitrogen from runoff, and adds nursery habitat inside a federal sturgeon zone.</figcaption>
      </figure>

      <div class="capital-stack">
        <article class="capital-row">
          <div class="capital-meta">
            <p class="capital-amount">2.7 ac</p>
            <p class="capital-source">Phase 1 wetland</p>
          </div>
          <div class="capital-detail">
            <h3>Wetland expansion at Fox Point Cove.</h3>
            <p>Phase 1 of the state plan restores 2.7 acres. A broader 2021 University of Delaware concept design grows the wetland from 1.69 up to 4.54 acres over time.</p>
          </div>
        </article>

        <article class="capital-row">
          <div class="capital-meta">
            <p class="capital-amount">~ 0.5 mi</p>
            <p class="capital-source">Stabilized edge</p>
          </div>
          <div class="capital-detail">
            <h3>A living shoreline along the industrial bank.</h3>
            <p>A vegetated edge stabilizes the eroding industrial bank and keeps sediment from washing into the river. Wave-break structures soften incoming wave action before it reaches the rail edge.</p>
          </div>
        </article>

        <article class="capital-row">
          <div class="capital-meta">
            <p class="capital-amount">N-scrub</p>
            <p class="capital-source">Nitrogen uptake</p>
          </div>
          <div class="capital-detail">
            <h3>Tidal marsh that pulls nitrogen from runoff.</h3>
            <p>Marsh plants pull up nitrogen — including ammonia, which is one of the inputs that drives oxygen loss in this stretch of the river. That makes the marsh complementary to the wastewater-plant upgrades the federal rule depends on.</p>
          </div>
        </article>

        <article class="capital-row">
          <div class="capital-meta">
            <p class="capital-amount">137 km</p>
            <p class="capital-source">Federal habitat</p>
          </div>
          <div class="capital-detail">
            <h3>Habitat inside a federal sturgeon zone.</h3>
            <p>Fox Point sits inside the 137-kilometer critical habitat the federal government has named as a sturgeon nursery and migration path. Restoration here adds usable nursery habitat where it counts.</p>
          </div>
        </article>
      </div>
    </section>

    <section class="panel" id="policy-funding">
      <div class="section-header">
        <div>
          <p class="section-label">Policy &amp; Funding</p>
          <h2>The pieces a Fox Point restoration could draw on.</h2>
        </div>
        <p class="section-copy">Federal, state, and county pieces are in place. The job is to line them up.</p>
      </div>

      <div class="corridor-brief-grid">
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">Federal</h3>
          <ul>
            <li>EPA Clean Water Act water quality standards (the new rule)</li>
            <li>NOAA Restoration Center — the $808K Hay Road settlement, with room to grow</li>
            <li>U.S. Fish and Wildlife Service endangered species partnerships</li>
            <li>NFWF Delaware River Watershed Conservation Fund</li>
            <li>EPA Urban Waters Federal Partnership</li>
          </ul>
        </article>
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">State (Delaware)</h3>
          <ul>
            <li>Delaware's January 2025 Damage Assessment and Restoration Plan, written by DNREC (the state environmental agency), which names Fox Point Cove</li>
            <li>2025 Delaware Climate Action Plan</li>
            <li>Wetlands Stewardship Act, introduced April 2026 by Sen. Stephanie Hansen and Rep. Debra Heffernan</li>
            <li>Heffernan Bond Bill pledge — $2.5M set aside for Fox Point inside a $3M state pledge, contingent on Edgemoor port construction and Diamond State Port Corporation approval</li>
          </ul>
        </article>
        <article class="corridor-brief-card">
          <h3 class="corridor-brief-eyebrow">County (New Castle)</h3>
          <ul>
            <li>County environmental review and permitting</li>
            <li>County trail and open space planning</li>
          </ul>
        </article>
      </div>

      <SourcesNote sources={[
        { label: 'DNREC DARP public notice WHS20250010', href: 'https://dnrec.delaware.gov/public-notices/whs20250010/' },
        { label: '2025 Delaware Climate Action Plan', href: 'https://documents.dnrec.delaware.gov/energy/Climate-Plan/2025-Delaware-Climate-Action-Plan.pdf' },
        { label: 'Wetlands Stewardship Act / Edgemoor expansion', href: 'https://senatedems.delaware.gov/2026/04/08/edgemoor-port-expansion-now-shovel-ready/' },
      ]} />
    </section>

    <section class="panel read-next" aria-label="Read next">
      <p class="section-label">Read Next</p>
      <div class="read-next-grid">
        <a class="read-next-card" href="/rail-corridor/">
          <p class="read-next-eyebrow">Rail Corridor</p>
          <h3>The rail line that runs through this habitat — and the climate risk on it.</h3>
          <span class="read-next-cta">Read →</span>
        </a>
        <a class="read-next-card" href="/what-this-means-for-delaware/">
          <p class="read-next-eyebrow">What This Means for Delaware</p>
          <h3>The transit and trail context a half-mile from the restoration site.</h3>
          <span class="read-next-cta">Read →</span>
        </a>
      </div>
    </section>

    <section class="panel" id="champions">
      <div class="section-header">
        <div>
          <p class="section-label">Champions</p>
          <h2>The people whose record and position make this work possible.</h2>
        </div>
      </div>
      <Champions ids={['mcbride', 'lambert', 'cartier', 'heffernan']} />
    </section>
  </main>
</BaseLayout>
