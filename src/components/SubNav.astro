---
interface Section {
  id: string;
  label: string;
}

interface Props {
  sections: Section[];
  ariaLabel?: string;
}

const { sections, ariaLabel = 'On this page' } = Astro.props;
---

<nav class="subnav" aria-label={ariaLabel} data-subnav>
  <ul class="subnav-list">
    {sections.map(({ id, label }) => (
      <li><a href={`#${id}`} data-subnav-link={id}>{label}</a></li>
    ))}
  </ul>
</nav>

<script>
  // Sticky sub-nav scroll-spy. Watches scroll position; toggles
  // is-current + aria-current="location" on the matching pill. Ports
  // the logic from the original app.js:20-70 and extends it to:
  //
  //  - keep the active pill visible inside the horizontal scroll-snap
  //    container on small screens
  //  - measure the sticky .page-header (Topbar + SubNav stacked) so
  //    the scroll-spy activation offset matches the actual height of
  //    everything pinned to the top of the viewport
  //  - scope every listener to an AbortController so view-transition
  //    re-init cleanly tears down the previous page's window listeners
  //    (otherwise scroll/resize handlers accumulate across navigations
  //    and keep firing against detached DOM nodes).
  let abortController: AbortController | null = null;

  function initSubNav() {
    abortController?.abort();
    abortController = new AbortController();
    const { signal } = abortController;

    const subnavs = document.querySelectorAll<HTMLElement>('[data-subnav]');
    if (!subnavs.length) return;

    subnavs.forEach((subnav) => {
      const links = Array.from(
        subnav.querySelectorAll<HTMLAnchorElement>('a[data-subnav-link]'),
      );
      if (!links.length) return;

      const sections = links
        .map((link) => {
          const id = link.dataset.subnavLink;
          return id ? document.getElementById(id) : null;
        })
        .filter((s): s is HTMLElement => s !== null);
      if (!sections.length) return;

      // Activation offset: distance from the top of the viewport at
      // which a section becomes the "current" one. The sticky element
      // is .page-header (Topbar + SubNav stacked), so we measure that
      // — not just the SubNav. BaseLayout's own script publishes the
      // same value as --page-header-height for scroll-padding-top.
      const getActivationOffset = () => {
        const pageHeader = document.querySelector<HTMLElement>('[data-page-header]');
        return (pageHeader?.getBoundingClientRect().height ?? 0) + 24;
      };

      const setActive = (id: string) => {
        links.forEach((link) => {
          const isCurrent = link.dataset.subnavLink === id;
          link.classList.toggle('is-current', isCurrent);
          if (isCurrent) {
            link.setAttribute('aria-current', 'location');
            // Keep the active pill visible inside the horizontal
            // scroll-snap container on small screens — but ONLY when
            // the list is actually a horizontal scroll container.
            //
            // On desktop the list is flex-wrap: wrap (no horizontal
            // overflow). Calling Element.scrollIntoView() there walks
            // up to the document as the nearest scrollable ancestor.
            // Combined with html { scroll-padding-top: ... } from the
            // sticky-bar offset, the browser treats the pill (visually
            // inside the sticky bar at viewport top) as "inside the
            // padded region" and smoothly scrolls the document to
            // bring it out of the pad — producing a ghost scroll on
            // every scroll-spy update and a feedback loop that makes
            // the page feel unresponsive to touch.
            //
            // Scoping the scroll explicitly to the .subnav-list (and
            // only when it actually overflows) keeps the horizontal
            // mobile scroll-into-center behavior while never touching
            // the document.
            const list = link.closest<HTMLElement>('.subnav-list');
            if (list && list.scrollWidth > list.clientWidth) {
              const linkRect = link.getBoundingClientRect();
              const listRect = list.getBoundingClientRect();
              const linkOffsetInList =
                linkRect.left - listRect.left + list.scrollLeft;
              const targetScroll =
                linkOffsetInList - (listRect.width - linkRect.width) / 2;
              // Respect prefers-reduced-motion. CSS scroll-behavior:auto
              // only governs user-agent-initiated scrolls; an explicit
              // behavior:'smooth' on Element.scrollTo() overrides it.
              const prefersReducedMotion = window.matchMedia(
                '(prefers-reduced-motion: reduce)',
              ).matches;
              list.scrollTo({
                left: targetScroll,
                behavior: prefersReducedMotion ? 'auto' : 'smooth',
              });
            }
          } else {
            link.removeAttribute('aria-current');
          }
        });
      };

      let frameId = 0;

      const updateActiveSection = () => {
        frameId = 0;
        const activationOffset = getActivationOffset();
        let activeSection: HTMLElement | null = null;
        for (const section of sections) {
          if (section.getBoundingClientRect().top <= activationOffset) {
            activeSection = section;
          }
        }
        if (activeSection) {
          setActive(activeSection.id);
        } else {
          // Above the first section — clear every pill.
          links.forEach((link) => {
            link.classList.remove('is-current');
            link.removeAttribute('aria-current');
          });
        }
      };

      const scheduleUpdate = () => {
        if (!frameId) {
          frameId = window.requestAnimationFrame(updateActiveSection);
        }
      };

      scheduleUpdate();
      window.addEventListener('scroll', scheduleUpdate, { passive: true, signal });
      window.addEventListener('resize', scheduleUpdate, { passive: true, signal });
      links.forEach((link) =>
        link.addEventListener('click', scheduleUpdate, { signal }),
      );
    });
  }

  document.addEventListener('astro:page-load', initSubNav);
</script>
