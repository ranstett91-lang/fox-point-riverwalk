---
const links = [
  { href: '/', label: 'Project' },
  { href: '/ecological-restoration/', label: 'Restoration' },
  { href: '/what-this-means-for-delaware/', label: 'Delaware' },
  { href: '/rail-corridor/', label: 'Rail' },
];

// Lowercase the pathname once so a user typing /RAIL-CORRIDOR/ in the
// address bar still marks the Rail link as current. URL paths are
// case-sensitive in the spec but Vercel typically lowercases at the
// edge; normalize defensively so direct-typed mixed-case URLs still
// resolve their topbar state.
const pathname = Astro.url.pathname.toLowerCase();

const isCurrent = (href: string) => {
  const target = href.toLowerCase();
  if (target === '/') {
    return pathname === '/' || pathname === '';
  }
  return pathname === target || pathname === target.replace(/\/$/, '');
};
---

<nav class="topbar" aria-label="Site sections">
  <a class="brandmark" href="/">Claymont to Fox Point</a>
  <div class="topbar-links">
    {links.map(({ href, label }) => (
      <a href={href} aria-current={isCurrent(href) ? 'page' : undefined} class:list={[{ 'is-current': isCurrent(href) }]}>{label}</a>
    ))}
  </div>
</nav>
